#!/bin/bash
# =============================================================================
# bin/wdroid — CLI principal do wdroid v2
# =============================================================================

set -euo pipefail

# Resolve symlink para encontrar o diretório real do projeto
SELF="$(readlink -f "$0")"
BASE_DIR="$(cd "$(dirname "$SELF")/.." && pwd)"

# Carrega núcleo
source "$BASE_DIR/core/config.sh"
source "$BASE_DIR/core/logger.sh"
source "$BASE_DIR/core/lock.sh"
source "$BASE_DIR/core/utils.sh"
source "$BASE_DIR/core/state.sh"

_init_logger

# Helper para carregar módulos on-demand
_load_modules() {
    for mod in "$@"; do
        # shellcheck source=/dev/null
        source "$BASE_DIR/modules/$mod.sh"
    done
}

_run_command() {
    local command_file="$1"
    shift || true
    [ -f "$BASE_DIR/commands/$command_file.sh" ] || die "Comando interno não encontrado: $command_file"
    # shellcheck source=/dev/null
    source "$BASE_DIR/commands/$command_file.sh" "$@"
}

_uses_soft_lock() {
    local command="$1"
    local subcommand="${2:-}"

    case "$command" in
        status|logs|doctor|help|--help|-h|version|apps)
            return 0
            ;;
        plugin)
            case "$subcommand" in
                ""|list|help|--help|-h) return 0 ;;
            esac
            ;;
        backup)
            case "$subcommand" in
                list|help|--help|-h) return 0 ;;
            esac
            ;;
        playstore)
            case "$subcommand" in
                ""|status|certify|help|--help|-h) return 0 ;;
            esac
            ;;
        micloud|mi-cloud)
            case "$subcommand" in
                ""|status|help|--help|-h) return 0 ;;
            esac
            ;;
    esac

    return 1
}

COMMAND="${1:-help}"
shift || true

if _uses_soft_lock "$COMMAND" "${1:-}"; then
    acquire_lock_soft
else
    acquire_lock
fi

case "$COMMAND" in
    # ── Ciclo de vida ─────────────────────────────────────────────────────────
    start)
        _run_command start "$@"
        ;;
    stop)
        _run_command stop "$@"
        ;;
    restart)
        _run_command restart "$@"
        ;;

    # ── Observabilidade ───────────────────────────────────────────────────────
    status)
        _run_command status "$@"
        ;;
    doctor)
        _run_command doctor "$@"
        ;;
    logs)
        _run_command logs "$@"
        ;;

    # ── Manutenção ────────────────────────────────────────────────────────────
    fix)
        _run_command fix "$@"
        ;;
    reset)
        _run_command reset "$@"
        ;;

    # ── Apps ──────────────────────────────────────────────────────────────────
    launch)
        _run_command launch "$@"
        ;;
    install-apk|apps|adb|screenshot|send-text|multi-window)
        _run_command app "$COMMAND" "$@"
        ;;
    playstore|micloud|mi-cloud)
        _run_command services "$COMMAND" "$@"
        ;;

    # ── Backup ────────────────────────────────────────────────────────────────
    backup)
        _run_command backup "$@"
        ;;

    # ── Plugins ───────────────────────────────────────────────────────────────
    plugin)
        _run_command plugin "$@"
        ;;

    # ── Instalação ────────────────────────────────────────────────────────────
    install)
        _run_command install "$@"
        ;;

    # ── Sistema ───────────────────────────────────────────────────────────────
    autostart|no-autostart)
        _run_command system "$COMMAND" "$@"
        ;;
    version)
        _run_command version "$@"
        ;;

    # ── Help ──────────────────────────────────────────────────────────────────
    help|--help|-h|"")
        _run_command help "$@"
        ;;

    *)
        error "Comando desconhecido: $COMMAND"
        echo "  Execute: wdroid help"
        exit 1
        ;;
esac
